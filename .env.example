# ==========================================================
# .env.example  — Template cho environment variables
#
# Cách dùng:
#   copy .env.example .env      (Windows)
#   cp .env.example .env        (Linux/Mac/WSL)
#
# Sau đó điền giá trị thực vào .env  (không commit .env lên git)
# ==========================================================

# ── MySQL (ERP Source) ─────────────────────────────────────
MYSQL_HOST=localhost
MYSQL_PORT=3306
MYSQL_USER=root
MYSQL_PASSWORD=your_mysql_password
MYSQL_DATABASE=your_erp_database

# ── PostgreSQL (DWH Target) ────────────────────────────────
PG_HOST=localhost
PG_PORT=5432
PG_USER=dwh_admin
PG_PASSWORD=your_strong_password_here
PG_DATABASE=erp_dwh

# ── PostgreSQL Superuser (chỉ dùng lần đầu cho elt/setup.py) ─
PG_SUPER_USER=postgres
PG_SUPER_PASSWORD=your_postgres_superuser_password
